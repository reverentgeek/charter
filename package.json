{
	"name": "chord-charter",
	"version": "4.1.0",
	"description": "Application to convert chordpro files to HTML or PDF",
	"main": "bin/index.js",
	"type": "module",
	"engines": {
		"node": "^22.16.0 || >=24.0.0"
	},
	"scripts": {
		"clean": "node tools/clean.js",
		"build:css": "node tools/sass.js",
		"build:html": "node tools/html.js",
		"build:htmlcolumns": "node tools/html.js --columns",
		"build": "pnpm run clean && pnpm run build:css && pnpm run build:html",
		"build:columns": "pnpm run clean && pnpm run build:css && pnpm run build:htmlcolumns",
		"convert": "pnpm run build && pnpm run pdf",
		"convert:columns": "pnpm run build:columns && pnpm run pdf",
		"lint": "eslint --fix",
		"pdf": "node tools/pdf.js",
		"prepare": "git config core.hooksPath .githooks",
		"start": "pnpm run convert",
		"test": "node --test --experimental-test-coverage"
	},
	"author": "David Neal <david@reverentgeek.com> (http://reverentgeek.com)",
	"license": "MIT",
	"dependencies": {
		"ejs": "^6.0.1",
		"handlebars": "^4.7.9",
		"puppeteer": "^25.2.1",
		"sass": "^1.101.0",
		"yargs": "^18.0.0"
	},
	"devDependencies": {
		"eslint": "^10.6.0",
		"eslint-config-reverentgeek": "^7.1.12"
	},
	"bin": {
		"chord-charter": "./bin/index.js"
	},
	"repository": "github:reverentgeek/charter",
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
